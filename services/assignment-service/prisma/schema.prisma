generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Assignment {
  id          String     @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  courseId    String
  createdAt   DateTime   @default(now())

  submissions Submission[]
}

model Submission {
  id           String     @id @default(cuid())
  fileUrl      String
  studentId    String
  assignmentId String
  createdAt    DateTime   @default(now())

  @@unique([studentId, assignmentId])
}
