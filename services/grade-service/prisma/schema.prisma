generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Grade {
  id           String   @id @default(cuid())
  score        Float
  comment      String?
  submissionId String   @unique
  gradedById   String
  createdAt    DateTime @default(now())
}
